{
  "version": 2,
  "regions": ["sin1"],
  "functions": {
    "api/[...slug].ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api/[...slug].ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
