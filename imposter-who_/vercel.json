{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/health(.*)",
      "destination": "/api/health.ts"
    },
    {
      "source": "/api/generate-word(.*)",
      "destination": "/api/generate-word.ts"
    },
    {
      "source": "/api/leaderboard(.*)",
      "destination": "/api/leaderboard.ts"
    },
    {
      "source": "/api/score(.*)",
      "destination": "/api/leaderboard.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
